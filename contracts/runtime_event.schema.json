{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mapper-toolkit/runtime_event.schema.json",
  "title": "Mapper-Toolkit Runtime Event",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "event_id",
    "event_type",
    "ts_utc",
    "ts_mono_ns",
    "trace_id",
    "span_id",
    "action_id",
    "device",
    "app",
    "payload"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": {
      "type": "string",
      "enum": [
        "ui_action_event",
        "network_request_event",
        "network_response_event",
        "cookie_event",
        "auth_event",
        "correlation_event",
        "extraction_event",
        "truncation_event",
        "triage_alert_event",
        "probe_phase_event",
        "provenance_event",
        "storage_event",
        "mission_event",
        "wizard_event",
        "overlay_anchor_event"
      ]
    },
    "ts_utc": { "type": "string", "format": "date-time" },
    "ts_mono_ns": { "type": ["integer", "number"] },
    "trace_id": { "type": "string" },
    "span_id": { "type": "string" },
    "action_id": { "type": "string" },
    "device": { "type": "object" },
    "app": { "type": "object" },
    "payload": { "type": ["object", "array", "string", "number", "boolean", "null"] }
  },
  "allOf": [
    {
      "if": { "properties": { "event_type": { "const": "network_request_event" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "request_id",
              "request_fingerprint",
              "phase_id",
              "target_site_id",
              "host_class",
              "normalized_host",
              "normalized_path",
              "normalized_scheme",
              "url",
              "method",
              "headers",
              "query_params",
              "request_body_summary",
              "request_operation",
              "request_flags",
              "correlation_refs"
            ],
            "properties": {
              "host_class": {
                "type": "string",
                "enum": [
                  "target_document",
                  "target_api",
                  "target_playback",
                  "target_asset",
                  "browser_bootstrap",
                  "google_noise",
                  "analytics_noise",
                  "background_noise",
                  "ignored"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "network_response_event" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "request_id",
              "response_id",
              "request_fingerprint",
              "phase_id",
              "target_site_id",
              "host_class",
              "normalized_host",
              "normalized_path",
              "normalized_scheme",
              "url",
              "method",
              "status_code",
              "mime_type",
              "content_length_header",
              "original_content_length",
              "stored_size_bytes",
              "capture_truncated",
              "truncation_reason",
              "body_capture_policy",
              "source_channel",
              "headers"
            ],
            "properties": {
              "host_class": {
                "type": "string",
                "enum": [
                  "target_document",
                  "target_api",
                  "target_playback",
                  "target_asset",
                  "browser_bootstrap",
                  "google_noise",
                  "analytics_noise",
                  "background_noise",
                  "ignored"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "cookie_event" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["operation", "domain", "phase_id"]
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "auth_event" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["operation", "phase_id"]
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "extraction_event" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "source_ref",
              "phase_id",
              "host_class",
              "extraction_kind",
              "success",
              "extracted_field_count",
              "confidence_summary"
            ],
            "properties": {
              "phase_id": {
                "type": "string",
                "enum": [
                  "home_probe",
                  "search_probe",
                  "detail_probe",
                  "playback_probe",
                  "auth_probe",
                  "background_noise"
                ]
              },
              "host_class": {
                "type": "string",
                "enum": [
                  "target_document",
                  "target_api",
                  "target_playback",
                  "target_asset",
                  "browser_bootstrap",
                  "google_noise",
                  "analytics_noise",
                  "background_noise",
                  "ignored"
                ]
              },
              "success": { "type": "boolean" },
              "extracted_field_count": { "type": "integer", "minimum": 0 },
              "source_ref": { "type": "string", "minLength": 1 },
              "extraction_kind": { "type": "string", "minLength": 1 },
              "confidence_summary": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "probe_phase_event" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["phase_id", "transition"],
            "properties": {
              "phase_id": {
                "type": "string",
                "enum": [
                  "home_probe",
                  "search_probe",
                  "detail_probe",
                  "playback_probe",
                  "auth_probe",
                  "background_noise"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "truncation_event" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "request_id",
              "response_id",
              "body_ref",
              "normalized_host",
              "normalized_path",
              "mime_type",
              "phase_id",
              "host_class",
              "capture_limit_bytes",
              "stored_size_bytes",
              "original_content_length",
              "truncation_reason",
              "body_capture_policy",
              "candidate_relevance"
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "provenance_event" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["entity_type", "entity_key", "phase_id"]
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "storage_event" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["storage_type", "key", "operation", "phase_id"]
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "mission_event" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "operation",
              "mission_id",
              "wizard_step_id",
              "saturation_state",
              "phase_id",
              "target_site_id",
              "export_readiness",
              "reason"
            ],
            "properties": {
              "operation": {
                "type": "string",
                "enum": [
                  "mission_selected",
                  "mission_config_applied",
                  "capture_started",
                  "capture_finished",
                  "export_requested",
                  "export_finalized"
                ]
              },
              "saturation_state": {
                "type": "string",
                "enum": ["INCOMPLETE", "NEEDS_MORE_EVIDENCE", "SATURATED", "BLOCKED"]
              },
              "export_readiness": {
                "type": "string",
                "enum": ["NOT_READY", "PARTIAL", "READY", "BLOCKED"]
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "wizard_event" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["operation", "mission_id", "wizard_step_id", "saturation_state", "phase_id", "target_site_id"],
            "properties": {
              "operation": {
                "type": "string",
                "enum": [
                  "wizard_started",
                  "wizard_step_started",
                  "wizard_step_saturation_updated",
                  "wizard_step_completed",
                  "wizard_step_blocked",
                  "wizard_finished"
                ]
              },
              "saturation_state": {
                "type": "string",
                "enum": ["INCOMPLETE", "NEEDS_MORE_EVIDENCE", "SATURATED", "BLOCKED"]
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "overlay_anchor_event" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["operation", "anchor_id", "name", "anchor_type", "phase_id", "target_site_id"],
            "properties": {
              "operation": {
                "type": "string",
                "enum": [
                  "overlay_anchor_created",
                  "overlay_anchor_labeled",
                  "overlay_anchor_removed"
                ]
              },
              "anchor_id": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 },
              "anchor_type": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "triage_alert_event" } } },
      "then": {
        "required": ["severity", "rule_id", "title", "reason"],
        "properties": {
          "severity": { "type": "string" },
          "rule_id": { "type": "string" },
          "title": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  ],
  "additionalProperties": true
}
