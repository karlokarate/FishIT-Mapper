{
  "name": "FishIT-Mapper Development",
  "image": "mcr.microsoft.com/devcontainers/java:21",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11",
      "installJupyterlab": true
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": false,
      "installOhMyZsh": false,
      "upgradePackages": true
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "fwcd.kotlin",
        "vscjava.vscode-gradle",
        "vscjava.vscode-java-pack",
        "EditorConfig.EditorConfig",
        "GitHub.vscode-pull-request-github",
        "eamodio.gitlens",
        "redhat.vscode-yaml",
        "yzhang.markdown-all-in-one",
        "Gruntfuggly.todo-tree",
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "openai.chatgpt"
      ],
      "settings": {
        "java.configuration.runtimes": [
          {
            "name": "JavaSE-21",
            "path": "/usr/lib/jvm/msopenjdk-current",
            "default": true
          }
        ],
        "github.copilot.enable": {
          "*": true,
          "kotlin": true,
          "java": true,
          "json": true,
          "markdown": true,
          "yaml": true
        },
        "github.copilot.chat.mcp.enabled": true,
        "mcp": {
          "servers": {
            "github": {
              "command": "docker",
              "args": [
                "run",
                "-i",
                "--rm",
                "-e",
                "GITHUB_PERSONAL_ACCESS_TOKEN",
                "ghcr.io/github/github-mcp-server"
              ],
              "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${localEnv:GITHUB_TOKEN}"
              }
            },
            "sequential-thinking": {
              "command": "npx",
              "args": [
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
              ]
            }
          }
        },
        "editor.formatOnSave": true,
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.rulers": [
          120
        ],
        "editor.inlineSuggest.enabled": true,
        "editor.bracketPairColorization.enabled": true,
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "files.exclude": {
          "**/.gradle": true,
          "**/build": true,
          "**/.idea": true
        },
        "files.watcherExclude": {
          "**/.gradle/**": true,
          "**/build/**": true,
          "**/node_modules/**": true
        },
        "[kotlin]": {
          "editor.tabSize": 4,
          "editor.insertSpaces": true
        },
        "[java]": {
          "editor.tabSize": 4,
          "editor.insertSpaces": true
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.persistentSessionScrollback": 1000,
        "terminal.integrated.shellIntegration.enabled": true,
        "remote.autoForwardPorts": true,
        "remote.restoreForwardedPorts": true
      }
    },
    "codespaces": {
      "openFiles": [
        "README.md"
      ]
    }
  },
  "forwardPorts": [
    8080,
    8888
  ],
  "portsAttributes": {
    "8888": {
      "label": "JupyterLab",
      "protocol": "http",
      "onAutoForward": "notify",
      "elevateIfNeeded": true
    }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postStartCommand": "echo '🚀 FishIT-Mapper ready!'",
  "remoteUser": "vscode",
  "remoteEnv": {
    "JAVA_HOME": "/usr/lib/jvm/msopenjdk-current",
    "ANDROID_HOME": "/home/vscode/.android-sdk",
    "ANDROID_SDK_ROOT": "/home/vscode/.android-sdk",
    "PATH": "${containerEnv:PATH}:/home/vscode/.android-sdk/cmdline-tools/latest/bin:/home/vscode/.android-sdk/platform-tools"
  },
  "mounts": [
    "source=fishit-gradle-cache,target=/home/vscode/.gradle,type=volume"
  ],
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },
  "waitFor": "onCreateCommand"
}
