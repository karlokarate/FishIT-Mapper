        {
          "step_id": "final_validation_export",
          "display_name": "Final Validation & Export",
          "optional": false,
          "phase_id": null,
          "browser_instruction": "Saettigung pruefen und missionrelevante Exporte finalisieren.",
          "required_signals": [
            "mission_relevant_export_artifacts_ready"
          ]
        },
        {
          "step_id": "auth_probe_step_optional",
          "display_name": "Auth Probe (Optional)",
          "optional": true,
          "phase_id": "auth_probe",
          "browser_instruction": "Optional anmelden, um Auth-/Refresh-Evidenz zu erfassen.",
          "required_signals": []
