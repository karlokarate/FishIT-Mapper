{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fishit-mapper/contracts/handover.schema.json",
  "title": "Session Handover",
  "type": "object",
  "required": [
    "schema_version",
    "handover_id",
    "generated_at_utc",
    "agent",
    "scope",
    "highlights",
    "changed_files"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "handover_id": {
      "type": "string",
      "pattern": "^HO-[0-9]{8}T[0-9]{6}Z$"
    },
    "generated_at_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "agent": {
      "type": "object",
      "required": [
        "name",
        "session_label"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "session_label": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "highlights": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "changed_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "status_code",
          "status",
          "path"
        ],
        "properties": {
          "status_code": {
            "type": "string",
            "enum": [
              "A",
              "M",
              "D",
              "R",
              "C",
              "U",
              "T",
              "?"
            ]
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "old_path": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
