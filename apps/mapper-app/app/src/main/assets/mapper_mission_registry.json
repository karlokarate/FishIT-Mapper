        "target_url_input",
        "home_probe_step",
        "search_probe_step",
        "detail_probe_step",
        "playback_probe_step",
        "final_validation_export"
      ],
      "optional_steps": [
        "auth_probe_step_optional"
      ],
      "steps": [
        {
          "step_id": "target_url_input",
          "display_name": "Target URL Input",
          "optional": false,
          "phase_id": null,
          "browser_instruction": "Ziel-URL eingeben und laden.",
          "required_signals": [
            "target_site_id_correlated"
          ]
        },
        {
          "step_id": "home_probe_step",
          "display_name": "Home Probe",
          "optional": false,
          "phase_id": "home_probe",
          "browser_instruction": "Startseite laden und stabilen Home-Traffic erzeugen.",
          "required_signals": [
            "home_candidate_count_min"
          ]
        },
        {
          "step_id": "search_probe_step",
          "display_name": "Search Probe",
          "optional": false,
          "phase_id": "search_probe",
          "browser_instruction": "Suche ausfuehren, bis Such-Traffic gesaettigt ist.",
          "required_signals": [
            "search_candidate_count_min",
            "field_matrix_search_mapping_present"
          ]
        },
        {
          "step_id": "detail_probe_step",
          "display_name": "Detail Probe",
          "optional": false,
          "phase_id": "detail_probe",
          "browser_instruction": "Detailseite oeffnen und Detail-Requests erfassen.",
          "required_signals": [
            "detail_candidate_count_min",
            "field_matrix_detail_mapping_present"
          ]
