      "mission_id": "FISHIT_PIPELINE",
      "display_name": "FishIT Pipeline",
      "description": "Build a FishIT-compatible provider draft with replay-minimized endpoint requirements for home, search, detail, playback, and auth when present.",
      "implemented": true,
      "availability_notes": "primary production mission in current cut",
      "required_probe_set": [
        "home_probe",
        "search_probe",
        "detail_probe",
        "playback_probe"
      ],
      "optional_probe_set": [
        "auth_probe",
        "replay_probe"
      ],
      "expected_output_targets": [
        "site_runtime_model",
        "fishit_provider_draft",
        "endpoint_templates",
        "field_matrix",
        "auth_draft",
        "playback_draft",
        "confidence_report",
        "warnings"
      ],
